# Model
BASE_MODEL_ID=microsoft/Phi-3-mini-128k-instruct

# LiveKit — get from cloud.livekit.io (project settings)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google Gemini — get from aistudio.google.com/api-keys (use non-supervised Google account)
GOOGLE_API_KEY=

# MiniMax — get from platform.minimax.io/user-center/basic-information
MINIMAX_GROUP_ID=
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_BASE_URL=https://api.minimax.io/v1

# DigitalOcean — claim $200 credits at the DO table (QR code) on-site
DIGITALOCEAN_TOKEN=
DIGITAL_OCEAN_MODEL_ACCESS_KEY=
DIGITAL_OCEAN_INFERENCE_BASE_URL=https://inference.do-ai.run/v1/
DIGITAL_OCEAN_JUDGE_MODEL=llama3.3-70b-instruct

# MongoDB Atlas — invite sent to attendees separately
MONGODB_URI=
MONGODB_DB_NAME=evolora
MONGODB_RUNS_COLLECTION=runs
MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000
