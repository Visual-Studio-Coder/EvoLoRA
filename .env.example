# Model (unsloth/Phi-3-mini-4k-instruct is verified to train on the A5000;
# unsloth/Meta-Llama-3.1-8B-Instruct also works but is slower)
BASE_MODEL_ID=unsloth/Phi-3-mini-4k-instruct

# Autonomy: true = no approval prompts, the loop runs itself to the target/judge
# (good for unattended runs); false = TUI asks to approve evals + whether to keep training.
AUTO_APPROVE=false

# Voice/LiveKit (optional, off by default; needs `pip install livekit`-style extras)
VOICE_ENABLED=false
# LiveKit — get from cloud.livekit.io (project settings)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google Gemini — get from aistudio.google.com/api-keys (use non-supervised Google account)
GOOGLE_API_KEY=

# MiniMax — get from platform.minimax.io/user-center/basic-information
MINIMAX_GROUP_ID=
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Remote GPU VM - blank SSH values keep config push in dry-run and runner in mock fallback
TRAINING_BACKEND=mock
MODEL_RUNNER=mock
SSH_HOST=
SSH_USER=
SSH_PORT=22
SSH_KEY_PATH=
REMOTE_CONFIG_PATH=/workspace/config.json
REMOTE_RESULTS_PATH=/workspace/generations/results.json

# DigitalOcean — claim $200 credits at the DO table (QR code) on-site
DIGITALOCEAN_TOKEN=
DIGITAL_OCEAN_MODEL_ACCESS_KEY=
DIGITAL_OCEAN_INFERENCE_BASE_URL=https://inference.do-ai.run/v1/
DIGITAL_OCEAN_JUDGE_MODEL=llama3.3-70b-instruct

# MongoDB Atlas — invite sent to attendees separately
MONGODB_URI=
MONGODB_DB_NAME=evolora
MONGODB_RUNS_COLLECTION=runs
MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000
